# Required for POST /api/cards/{id}/generate
OPENAI_API_KEY=
# Current image model; override if your project uses a different available model.
OPENAI_IMAGE_MODEL=gpt-image-2

# Optional ESP32 EPD base address, e.g. http://192.168.1.50
# POST /api/cards/{id}/epd configures gdey042z98 in tricolor mode, then uploads
# a 30,000-byte frame to <EPD_UPLOAD_URL>/api/frame.
EPD_UPLOAD_URL=
EPD_API_TOKEN=
